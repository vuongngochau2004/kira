# ===================================
# K.I.R.A Simplified Environment Variables
# Copy this file to .env and fill in values
# ===================================

# ----- Application -----
APP_NAME=kira-simple
APP_ENV=development
DEBUG=true
SECRET_KEY=your-secret-key-change-this

# ----- PostgreSQL -----
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5433
POSTGRES_USER=kira
POSTGRES_PASSWORD=kira_secret
POSTGRES_DB=kira_dev

# ----- Qdrant (Vector DB) -----
QDRANT_HOST=127.0.0.1
QDRANT_PORT=6333
# QDRANT_COLLECTION and QDRANT_VECTOR_DIM are in config/settings.yaml

# ----- MinIO (Object Storage) -----
MINIO_ENDPOINT=127.0.0.1:9000
MINIO_ACCESS_KEY=kira_minio
MINIO_SECRET_KEY=kira_minio_secret
MINIO_BUCKET=kira-documents
MINIO_SECURE=false

# ----- JWT Auth -----
JWT_SECRET_KEY=your-jwt-secret-change-this
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=30
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ----- LLM Provider -----
LLM_PROVIDER=glm

# Z.ai GLM (default for Vietnamese)
GLM_API_URL=https://api.z.ai/api/anthropic
GLM_API_KEY=your-glm-api-key
GLM_MODEL=glm-4.5

# BK Self-hosted LLM (OpenAI-compatible)
BK_LLM_BASE_URL=https://llm.example.com/v1
BK_LLM_MODEL=google/gemma-3-27b-it
BK_API_KEY=not-needed

# Google Gemini (backup)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.0-flash

# OpenAI (optional)
OPENAI_API_KEY=your-openai-api-key

# ----- Embedding -----
EMBEDDING_PROVIDER=aivn
EMBEDDING_BASE_URL=http://your-linux-server-ip:8888
EMBEDDING_MODEL=vietnamese-embedding-v2
# EMBEDDING_DIM is in config/settings.yaml

# Retrieval & Chunking parameters are in config/settings.yaml

# ----- CORS -----
CORS_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001,http://localhost:8006

# ----- Auth (development mode) -----
# Set to false to bypass JWT auth for local development (NEVER false in production!)
AUTH_ENABLED=true
